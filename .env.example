# ============= SERVIDOR =============
NODE_ENV=development
PORT=3000

# ============= BASE DE DATOS =============
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_MAX_CONNECTIONS=10

# ============= AUTENTICACIÓN JWT =============
JWT_SECRET=xyz123
JWT_EXPIRATION=24h

# ============= CORS Y SEGURIDAD =============
CORS_ORIGIN=http://localhost:5173
API_BASE_URL=http://localhost:3000/api
FRONTEND_URL=http://localhost:5173

# ============= RATE LIMITING =============
RATE_LIMIT_WINDOW_MS=15000
RATE_LIMIT_MAX_REQUESTS=100

# ============= ENCRIPTACIÓN =============
BCRYPT_ROUNDS=10
SESSION_SECRET=session-secret-key

# ============= PAGINACIÓN =============
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# ============= LOGGING =============
LOG_LEVEL=info

# ============= EMAIL (Opcional) =============
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@scouts.com
