# ==========================================
# DESARROLLO LOCAL - Copiar este archivo a .env.local y completar
# ==========================================

# Servidor
NODE_ENV=development
PORT=3000

# Base de datos - OPCIÓN 1: DATABASE_URL (para testear con Vercel Postgres)
# Descomenta y usa DATABASE_URL si quieres testear localmente contra Vercel Postgres
# DATABASE_URL=postgresql://user:password@host:port/database

# Base de datos - OPCIÓN 2: Variables individuales (desarrollo local)
# Usa estas si prefieres PostgreSQL local
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gsp_development
DB_USER=postgres
DB_PASSWORD=postgres
DB_MAX_CONNECTIONS=10

# Seguridad (cambiar en producción)
JWT_SECRET=dev-secret-key-change-in-production
SESSION_SECRET=dev-session-key-change-in-production
BCRYPT_ROUNDS=10

# CORS (para desarrollo local)
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=debug

# Rate Limiting (menos restrictivo en desarrollo)
RATE_LIMIT_WINDOW_MS=15000
RATE_LIMIT_MAX_REQUESTS=1000

# Email (opcional, dejar en blanco si no se usa)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@scouts.com

# URLs
API_BASE_URL=http://localhost:3000/api
FRONTEND_URL=http://localhost:5173
